<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.2"
             xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
    <persistence-unit name="team7">
        <!-- AGGIUNGERE SEMPRE LA CLASSE -->

        <class>team7.entities.Abbonamento</class>
        <class>team7.entities.Biglietto</class>
        <class>team7.entities.DistributoreAutomatico</class>
        <class>team7.entities.Mezzo</class>
        <class>team7.entities.Percorrenza</class>
        <class>team7.entities.PeriodoStatoMezzo</class>
        <class>team7.entities.Rivenditore</class>
        <class>team7.entities.RivenditoreAutorizzato</class>
        <class>team7.entities.Tessera</class>
        <class>team7.entities.TitoloViaggio</class>
        <class>team7.entities.Tratta</class>
        <class>team7.entities.Utente</class>
        <properties>
            <!-- riferimenti al database -->
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:postgresql://localhost:5432/team7"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <!-- per aggoirnare/creare automaticamente all'avio -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit>
</persistence>